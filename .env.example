# GitHub API token for the leaderboard queries.
# A classic token with public repo read access (or a fine-grained read-only
# token) is enough, since nuxt/nuxt is public.
NUXT_GITHUB_TOKEN=

# Admin page credentials (toggling prizes, manual credits, forced refresh).
NUXT_ADMIN_USER=
NUXT_ADMIN_PASSWORD=

# GitHub OAuth app for the community chat login (nuxt-auth-utils).
# Callback URL: <origin>/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
# Secret for sealing the session cookie, >= 32 chars (openssl rand -base64 32).
NUXT_SESSION_PASSWORD=
