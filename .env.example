# GitHub API token for the leaderboard queries.
# A classic token with public repo read access (or a fine-grained read-only
# token) is enough, since nuxt/nuxt is public.
NUXT_GITHUB_TOKEN=

# Admin page credentials (toggling prizes, manual credits, forced refresh).
NUXT_ADMIN_USER=
NUXT_ADMIN_PASSWORD=

# Upstash Redis REST credentials. Production only; local dev uses the filesystem.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
